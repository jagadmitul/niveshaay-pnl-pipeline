# Vite reads this at build/dev time. Copy to `.env.local` and adjust.
#
# By default the frontend hits `/api/process-pdf` which the Vite dev server
# proxies to `${VITE_N8N_BASE_URL}/webhook/process-pdf`. This keeps the request
# same-origin and dodges a known n8n CORS issue where the production webhook
# returns an empty body to cross-origin POSTs.

VITE_N8N_BASE_URL=http://localhost:5678

# Optional: override the full webhook URL (useful for production deploys that
# don't go through the Vite dev server). When set, this takes precedence and
# the proxy is bypassed.
# VITE_N8N_WEBHOOK_URL=https://your-n8n-host/webhook/process-pdf
