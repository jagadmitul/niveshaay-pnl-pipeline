# =============================================================================
# Niveshaay P&L Pipeline - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in actual values.
# DO NOT commit `.env` to version control.

# -----------------------------------------------------------------------------
# Gemini API
# -----------------------------------------------------------------------------
# Get your key from https://aistudio.google.com/apikey
#
# Model choice:
#   - gemini-2.5-flash   fast + cheap (~$0.10 per filing). Good default. May
#                        occasionally pick the standalone section in PDFs that
#                        contain both standalone and consolidated statements.
#   - gemini-2.5-pro     slower + ~3× cost (~$0.30 per filing). Higher accuracy
#                        at following the "prefer consolidated" prompt directive.
#                        Recommended for production accuracy.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# -----------------------------------------------------------------------------
# n8n (set inside docker-compose or n8n environment)
# -----------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change_me_to_a_random_64_char_string
GENERIC_TIMEZONE=Asia/Kolkata

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# URL where the React frontend should call the n8n webhook
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/process-pdf
